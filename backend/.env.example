# Server configuration
HOST=127.0.0.1
PORT=8001

# Mock Mode (Set to true to simulate API calls without reaching Banco do Brasil endpoints)
MOCK_MODE=true

# BB API URL configuration
# Homologation: https://fgo.mtls.api.hm.bb.com.br/v2
# Production: https://fgo.mtls.api.bb.com.br/v2
BB_FGO_BASE_URL=https://fgo.mtls.api.hm.bb.com.br/v2

# BB OAuth2 Token URL
# Homologation: https://oauth.hm.bb.com.br/oauth/token
# Production: https://oauth.bb.com.br/oauth/token
BB_OAUTH_TOKEN_URL=https://oauth.hm.bb.com.br/oauth/token

# BB Credentials
BB_CLIENT_ID=seu_client_id_aqui
BB_CLIENT_SECRET=seu_client_secret_aqui
BB_GW_DEV_APP_KEY=sua_developer_application_key_aqui

# mTLS Certificate configuration (relative to backend/ or absolute)
BB_CERT_PATH=certs/client_cert.pem
BB_KEY_PATH=certs/client_key.pem
